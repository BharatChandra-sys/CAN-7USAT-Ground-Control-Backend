# ═══════════════════════════════════════════════════════
#  GARI GCS — CAN-7USAT Ground Control Station
#  .gitignore
# ═══════════════════════════════════════════════════════

# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
MANIFEST

# ── Virtual Environment ──────────────────────────────────
venv/
env/
ENV/
.venv/

# ── Node / Frontend ─────────────────────────────────────
node_modules/
frontend/dist/
frontend/build/
.vite/
.cache/

# ── Logs ────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Environment / Secrets ───────────────────────────────
.env
.env.local
.env.*.local
backend/.env
# Keep examples
!backend/.env.example
!frontend/.env.rocket

# ── IDEs ────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.sixth/

# ── OS ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Testing / Coverage ──────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/
coverage/
*.lcov

# ── Database ────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Temp / Build artifacts ──────────────────────────────
*.tmp
*.bak
temp_frontend/

# ── Project-specific large binary files ─────────────────
rckt_kushinagar.csv
rckt_inspace.ork

# ── PDFs (keep in docs/ only) ───────────────────────────
*.pdf
!docs/*.pdf

# ── Screenshots / raw images (keep docs/images) ─────────
Screenshot*.png
Screenshot*.jpg
Screenshot*.PNG
Screenshot*.JPG

# ── Keep these tracked ──────────────────────────────────
!docs/images/*.png
!docs/images/*.jpg
!docs/images/*.svg
!README.md
!LICENSE

# ── Extra generated markdown (not needed in repo) ───────
SETUP_STATUS.md
BACKEND_COMPLETE.md
SYSTEM_UPGRADES.md
FINAL_STATUS.md
